{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "express",
  "nodeVersion": "20.x",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
